  20:main.c        **** 
  21:main.c        **** #include <project.h>
  22:main.c        **** 
  23:main.c        **** #define CLK_IMO_MHZ                 (32u)
  24:main.c        **** #define SYSCLK_DIVIDER              (2u)
  25:main.c        **** 
  26:main.c        **** #define HZ_IN_MHZ                   (1000000u)
  27:main.c        **** #define BLINK_DELAY_MS              (1000u)
  28:main.c        **** #define VISIBILITY_DELAY_MS         (1000u)
  29:main.c        **** 
  30:main.c        **** #define WAIT_IMO_TO_SETTLE          (1u)
ARM GAS  C:\Users\hamis\AppData\Local\Temp\ccrvUx4B.s 			page 2


  31:main.c        **** #define WAIT_PLL_TO_SETTLE          (1u)
  32:main.c        **** #define IMO_FREQ                    (CY_IMO_FREQ_3MHZ) /* CyIMO_SetFreq() parameter */
  33:main.c        **** 
  34:main.c        **** 
  35:main.c        **** #define LED_OFF                     (0u)
  36:main.c        **** #define LED_ON                      (1u)
  37:main.c        **** 
  38:main.c        **** #define PLL_Q                       (1u)    /* 1 MHz <= (Fin / Q) <= 3 MHz */
  39:main.c        **** #define PLL_P                       (16u)   /* Fout = Fin * P/Q */
  40:main.c        **** #define PLL_ICP                     (1u)    /* Valid for all configurations */
  41:main.c        **** 
  42:main.c        **** /* Conversion between CyIMO_SetFreq() parameter and frequency in 3-62 MHz range */
  43:main.c        **** const uint8 CYCODE imoFreqParam2Frequency[6u] = {3u, 6u, 12u, 24u, 48, 62u};
  44:main.c        **** 
  45:main.c        **** /* Function prototype */
  46:main.c        **** void Led_Blink(void);
  47:main.c        **** 
  48:main.c        **** 
  49:main.c        **** /*******************************************************************************
  50:main.c        **** * Function Name: main
  51:main.c        **** ********************************************************************************
  52:main.c        **** *
  53:main.c        **** * Summary:
  54:main.c        **** *  Reconfigures the clock tree from "XTAL -> Master Clock -> Bus Clock" to "IMO
  55:main.c        **** *  -> PLL -> Master Clock -> Bus Clock". Reconfigures ILO 1 KHz to route it out
  56:main.c        **** *  of the ILO block instead of ILO 100 KHz. Disables the unused clock source:
  57:main.c        **** *  XTAL and ILO 100 KHz. The LCD displays the execution status. The LED blinks
  58:main.c        **** *  twice for the same period of time before clock configuration changes and
  59:main.c        **** *  after.
  60:main.c        **** *
  61:main.c        **** * Parameters:
  62:main.c        **** *  None
  63:main.c        **** *
  64:main.c        **** * Return:
  65:main.c        **** *  None
  66:main.c        **** *
  67:main.c        **** *******************************************************************************/
  68:main.c        **** int main(void)
  69:main.c        **** {
  70:main.c        ****     LCD_Start();
  71:main.c        ****     LCD_Position(0u, 0u);
  72:main.c        ****     LCD_PrintString("Clock Example");
  73:main.c        **** 
  74:main.c        ****     Led_Blink();
  75:main.c        **** 
  76:main.c        ****     /* Configure and start IMO */
  77:main.c        ****     CyIMO_SetFreq(IMO_FREQ);
  78:main.c        **** 
  79:main.c        ****     /* PLLout = Fimo * P /Q */
  80:main.c        ****     CyPLL_OUT_SetPQ(PLL_P, PLL_Q, PLL_ICP);
  81:main.c        ****     CyIMO_Start(WAIT_IMO_TO_SETTLE);
  82:main.c        **** 
  83:main.c        ****     /* Configure and start PLL */
  84:main.c        ****     CyPLL_OUT_SetSource(CY_PLL_SOURCE_IMO);
  85:main.c        ****     if(CYRET_SUCCESS == CyPLL_OUT_Start(WAIT_PLL_TO_SETTLE))
  86:main.c        ****     {
  87:main.c        ****         /***********************************************************************
ARM GAS  C:\Users\hamis\AppData\Local\Temp\ccrvUx4B.s 			page 3


  88:main.c        ****         * Set the number of clock cycles the cache waits before it samples
  89:main.c        ****         * data coming back from the Flash. This function must be called before
  90:main.c        ****         * increasing the CPU clock frequency. It can optionally be called after
  91:main.c        ****         * lowering the CPU clock frequency to improve the CPU performance.
  92:main.c        ****         ***********************************************************************/
  93:main.c        ****         CyFlash_SetWaitCycles(imoFreqParam2Frequency[IMO_FREQ] * PLL_P / PLL_Q);
  94:main.c        **** 
  95:main.c        **** 
  96:main.c        ****         /***********************************************************************
  97:main.c        ****         * Adjustments to keep the CyDelay function accurate.
  98:main.c        ****         * By default, the number of cycles to delay in CyDelay() and CyDelayUs()
  99:main.c        ****         * is calculated based on the clock configuration entered in PSoC Creator.
 100:main.c        ****         * If the clock configuration changes at the run-time, the CyDelayFreq()
 101:main.c        ****         * function is used to indicate a new frequency.
 102:main.c        ****         ***********************************************************************/
 103:main.c        ****         CyDelayFreq(HZ_IN_MHZ * imoFreqParam2Frequency[IMO_FREQ] * PLL_P / PLL_Q);
 104:main.c        **** 
 105:main.c        ****         /* Change Master clock source to PLL */
 106:main.c        ****         CyMasterClk_SetSource(CY_MASTER_SOURCE_PLL);
 107:main.c        **** 
 108:main.c        ****         /* Master clock is not sourced by XTAL - safe to stop it */
 109:main.c        ****         CyXTAL_Stop();
 110:main.c        ****     }
 111:main.c        ****     else
 112:main.c        ****     {
 113:main.c        ****         LCD_Position(1u, 0u);
 114:main.c        ****         LCD_PrintString("PLL - Failed.");
 115:main.c        ****         CyDelay(VISIBILITY_DELAY_MS);
 116:main.c        ****     }
 117:main.c        **** 
 118:main.c        ****     /* ILO 1 KHz is enabled by default, so route ILO 1 KHz and disable 100 KHz */
 119:main.c        ****     CyILO_SetSource(CY_ILO_SOURCE_1K);
 120:main.c        ****     CyILO_Stop100K();
 121:main.c        **** 
 122:main.c        ****     LCD_Position(1u, 0u);
 123:main.c        ****     LCD_PrintString("Reconfigured");
 124:main.c        **** 
 125:main.c        ****     Led_Blink();
 126:main.c        **** 
 127:main.c        ****     for(;;)
 128:main.c        ****     {
 129:main.c        ****     }
 130:main.c        **** 
 131:main.c        **** }
 132:main.c        **** 
