  70:main.c        **** #define DIAG_PERIOD_MS        1000u   /* 1 Hz diagnostic print (MOVI_CONTROL)  */
  71:main.c        **** #define TEST_TIMEOUT_MS       2000u   /* test mode: max wait for response       */
  72:main.c        **** #define SCAN_TIMEOUT_MS        500u   /* scan mode: max wait per attr           */
  73:main.c        **** #define SCAN_BATCH_SIZE        200u   /* attrs per batch before pausing         */
  74:main.c        **** #define SCAN_ATTR_MIN          801u   /* first attr to scan                     */
  75:main.c        **** #define SCAN_ATTR_MAX         2400u   /* last attr to scan (inclusive)          */
  76:main.c        **** #define SCAN_TX_BUF_SIZE        16u   /* enough for any QX read-request frame   */
  77:main.c        **** 
  78:main.c        **** #define RESET_POLL_MS         1000u   /* poll attr 382 echo at 1 Hz             */
  79:main.c        **** #define RESET_TIMEOUT_MS     15000u   /* abort if still active after 15 s       */
  80:main.c        **** #define SENSOR_POLL_MS         600u   /* ms between sensor attr polls           */
