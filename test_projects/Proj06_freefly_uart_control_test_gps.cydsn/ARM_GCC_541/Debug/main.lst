 116:main.c        **** 
 117:main.c        **** /* =========================================================================
 118:main.c        ****  * Initialize movi connection!
 119:main.c        ****  * 
 120:main.c        ****  * In order to handle the Movi gracefully in C, and allow multiple connections,
 121:main.c        ****  * we need to create a hardware abstraction layer (HAL). Rather than the code 
 122:main.c        ****  * calling the serial directly, we pass the code a pointer to the hardware!
 123:main.c        ****  *
 124:main.c        ****  * It also means its agnostic to comm type! We can give it a way to put to
 125:main.c        ****  * UART just as well as CAN, Linux serial, or a loopback. The three parts are:
 126:main.c        ****  * 1. movi_uart_putc function - The only piece that talks to the hardware.
 127:main.c        ****  * 2. movi_hal_t struct - Holds pointer to the putc function
 128:main.c        ****  * 3. ctx pointer - Handling multiple gimbals. If multiple are needed, the putc
 129:main.c        ****  *    would need to take the ctx as a context for the UART handle to use in a 
 130:main.c        ****  * specific command.
 131:main.c        ****  * 
 132:main.c        ****  * HAL only handles Tx to the Movi, the Rx is handled by an ISR which does not
 133:main.c        ****  * differentiate between two devices, would need seperate UART UDB with its own
 134:main.c        ****  * ISR.
 135:main.c        ****  *
 136:main.c        ****  * ========================================================================= */
 137:main.c        **** static movi_comm_t g_movi;
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccM52HEI.s 			page 14


