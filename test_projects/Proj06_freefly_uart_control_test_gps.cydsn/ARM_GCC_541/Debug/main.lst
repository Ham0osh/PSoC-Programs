 221:main.c        **** 
 222:main.c        **** /* -------------------------------------------------------------------------
 223:main.c        ****  * Test print functions — all take (dt, rxlen, snapshot_payload, snap_plen).
 224:main.c        ****  * Raw values are read directly from the snapshot bytes (p), not from
 225:main.c        ****  * movi_status_t floats, to guarantee we see exactly what the GCU sent
 226:main.c        ****  * before the next attr 287 push could overwrite RxMsg.
 227:main.c        ****  * ------------------------------------------------------------------------- */
 228:main.c        **** 
 229:main.c        **** /* Macro: read int16 LE from snapshot at byte offset off.
 230:main.c        ****  * Returns 0 if snapshot is too short.                    */
 231:main.c        **** #define SNAP16(p, plen, off) \
 232:main.c        ****     (((off) + 2u <= (plen)) ? ({ int16_t _v; memcpy(&_v, (p)+(off), 2); _v; }) : (int16_t)0)
 233:main.c        **** 
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccHH9OS0.s 			page 24


 234:main.c        **** /* Macro: read int32 LE from snapshot at byte offset off. */
 235:main.c        **** #define SNAP32(p, plen, off) \
 236:main.c        ****     (((off) + 4u <= (plen)) ? ({ int32_t _v; memcpy(&_v, (p)+(off), 4); _v; }) : (int32_t)0)
 237:main.c        **** 
 238:main.c        **** /* Macro: read int16 big-endian from snapshot. */
 239:main.c        **** #define SNAP16BE(p, plen, off) \
 240:main.c        ****     (((off) + 2u <= (plen)) \
 241:main.c        ****         ? (int16_t)(((uint16_t)(p)[(off)] << 8) | (uint16_t)(p)[(off)+1u]) \
 242:main.c        ****         : (int16_t)0)
 243:main.c        **** 
 244:main.c        **** /* Macro: read int32 big-endian from snapshot. */
 245:main.c        **** #define SNAP32BE(p, plen, off) \
 246:main.c        ****     (((off) + 4u <= (plen)) \
 247:main.c        ****         ? (int32_t)(  ((uint32_t)(p)[(off)]   << 24) \
 248:main.c        ****                     | ((uint32_t)(p)[(off)+1u] << 16) \
