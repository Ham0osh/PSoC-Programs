   1:main.c        **** /* main.c
   2:main.c        ****  * Author: Hamish Johnson
   3:main.c        ****  * Org: Quantum Internet Systems Lab, SFU, Physics
   4:main.c        ****  * Date: March 9 2026
   5:main.c        ****  * 
   6:main.c        ****  * Uses:
   7:main.c        ****  *  - adc_balanced.c/.h  : round-robin ADC sampling over AMux (N_CH channels)
   8:main.c        ****  *  - joystick.c/.h      : calibration + mapping (deadband, inversion, scaling)
   9:main.c        ****  *  - movi_comm.c/.h     : MōVI Pro QX protocol HAL
  10:main.c        ****  *
  11:main.c        ****  * CLI:
  12:main.c        ****  *   'j' : toggle joystick active (feeds pan/tilt commands)
  13:main.c        ****  *   'm' : toggle movi comms active (sends QX packets)
  14:main.c        ****  *   'l' : cycle control mode DEFER -> RATE -> ABSOLUTE -> DEFER (both axes)
  15:main.c        ****  *   'k' : kill motion + reset mode to DEFER, keep printing
  16:main.c        ****  *   'x' : kill motion + reset mode to DEFER + stop diagnostic printing
  17:main.c        ****  *   's' : toggle raw ADC stream (debug)
  18:main.c        ****  *   'c' : calibration advance
  19:main.c        ****  */
  20:main.c        **** 
