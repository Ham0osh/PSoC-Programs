   1:main.c        **** /* main.c
   2:main.c        ****  * Author: Hamish Johnson
   3:main.c        ****  * Org: Quantum Internet Systems Lab, SFU, Physics
   4:main.c        ****  * Date: March 2026
   5:main.c        ****  *
   6:main.c        ****  * Uses:
   7:main.c        ****  *  - adc_balanced.c/.h  : round-robin ADC sampling over AMux (N_CH channels)
   8:main.c        ****  *  - joystick.c/.h      : calibration + mapping (deadband, inversion, scaling)
   9:main.c        ****  *  - movi_comm.c/.h     : MōVI Pro QX protocol HAL
  10:main.c        ****  *
  11:main.c        ****  * Application modes (app_mode):
  12:main.c        ****  *   STANDBY      : passive — pump() runs, diag prints [Status] at 1 Hz if valid
  13:main.c        ****  *   MOVI_CONTROL : sends QX277 at 10 Hz, 1 Hz diag w/ [Serial][Status][Joystick]
  14:main.c        ****  *   MOVI_TEST    : one-shot query mode — sends single attr read, prints verbose
  15:main.c        ****  *                  response or 2-second timeout.  No periodic TX or diag block.
  16:main.c        ****  *
  17:main.c        ****  * CLI keys — STANDBY / MOVI_CONTROL:
  18:main.c        ****  *   m : toggle STANDBY <-> MOVI_CONTROL
  19:main.c        ****  *   j : toggle joystick active (feeds pan/tilt commands)
  20:main.c        ****  *   l : cycle control mode DEFER -> RATE -> ABSOLUTE -> DEFER
  21:main.c        ****  *   k : kill motion, return to STANDBY, keep printing
  22:main.c        ****  *   x : kill motion, return to STANDBY, stop printing
  23:main.c        ****  *   s : toggle raw ADC stream
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccHH9OS0.s 			page 2


  24:main.c        ****  *   c : calibration advance
  25:main.c        ****  *   t : enter MOVI_TEST mode (from STANDBY only)
  26:main.c        ****  *
  27:main.c        ****  * CLI keys — MOVI_TEST:
  28:main.c        ****  *   a : request attr 22  — gimbal attitude (euler: roll/pitch/yaw + errors + rates)
  29:main.c        ****  *   g : request attr  4  — GPS (lat/lon/alt/speed/heading/accuracy)
  30:main.c        ****  *   b : request attr  3  — baro altitude + rate of climb
  31:main.c        ****  *   s : request attr  1  — system status (battery, sats, temp, CPU, pressure)
  32:main.c        ****  *   n : request attr 12  — magnetometer (XYZ, magnitude, freq, offsets, declination)
  33:main.c        ****  *   t : exit MOVI_TEST, return to STANDBY
  34:main.c        ****  *   k/x : kill + exit to STANDBY
  35:main.c        ****  */
  36:main.c        **** 
