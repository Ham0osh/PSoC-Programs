   1:main.c        **** /* main.c
   2:main.c        ****  * Author: Hamish Johnson
   3:main.c        ****  * Org: Quantum Internet Systems Lab, SFU, Physics
   4:main.c        ****  * Date: March 2026
   5:main.c        ****  *
   6:main.c        ****  * Uses:
   7:main.c        ****  *  - adc_balanced.c/.h  : round-robin ADC sampling over AMux (N_CH channels)
   8:main.c        ****  *  - joystick.c/.h      : calibration + mapping (deadband, inversion, scaling)
   9:main.c        ****  *  - movi_comm.c/.h     : MōVI Pro QX protocol HAL
  10:main.c        ****  *
  11:main.c        ****  * Application modes (app_mode):
  12:main.c        ****  *   STANDBY      : passive — pump() runs, diag prints [Status] at 1 Hz if valid
  13:main.c        ****  *   MOVI_CONTROL : sends QX277 at 10 Hz, 1 Hz diag w/ [Serial][Status][Joystick]
  14:main.c        ****  *   MOVI_TEST    : one-shot query mode — sends single attr read, prints verbose
  15:main.c        ****  *                  response or 2-second timeout.  No periodic TX or diag block.
  16:main.c        ****  *   MOVI_SCAN    : exhaustive attr sweep (existing)
  17:main.c        ****  *   RESET        : attr 382 heading-reset sequence (test 1)
  18:main.c        ****  *   SENSOR       : continuous compact sensor stream, no GPS needed
  19:main.c        ****  *
  20:main.c        ****  * CLI keys — STANDBY:
  21:main.c        ****  *   m : toggle STANDBY <-> MOVI_CONTROL
  22:main.c        ****  *   t : enter MOVI_TEST mode
  23:main.c        ****  *   w : enter MOVI_SCAN mode
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccHAXXh1.s 			page 2


  24:main.c        ****  *   r : enter RESET mode  (test 1 — attr 382 heading reset)
  25:main.c        ****  *   v : enter SENSOR mode (indoor sensor validation)
  26:main.c        ****  *   j : toggle joystick active
  27:main.c        ****  *   l : cycle control mode DEFER -> RATE -> ABSOLUTE -> DEFER
  28:main.c        ****  *   k : kill motion + STANDBY      x : kill + STANDBY + quiet
  29:main.c        ****  *   s : toggle raw ADC stream      c : calibration advance
  30:main.c        ****  *
  31:main.c        ****  * CLI keys — MOVI_CONTROL:
  32:main.c        ****  *   (all STANDBY keys, plus:)
  33:main.c        ****  *   f : one-shot attr 48 read  (test 4 — motor drive status)
  34:main.c        ****  *   p : toggle platform-yaw display in 1 Hz diag  (M2 — attr 2)
  35:main.c        ****  *   0..5 : absolute angle presets  (test 2 — requires 'l' to select ABS first)
  36:main.c        ****  *          0=home(0,0)  1=pan+45  2=pan-45  3=tilt+30  4=tilt-30  5=pan+90
  37:main.c        ****  *
  38:main.c        ****  * CLI keys — MOVI_TEST:
  39:main.c        ****  *   a : attr 22  — gimbal Euler attitude
  40:main.c        ****  *   g : attr  4  — GPS
  41:main.c        ****  *   b : attr  3  — baro altitude
  42:main.c        ****  *   s : attr  1  — system status
  43:main.c        ****  *   n : attr 12  — magnetometer
  44:main.c        ****  *   2 : attr  2  — platform body attitude  (M2)
  45:main.c        ****  *   4 : attr 48  — motor drive status      (test 4)
  46:main.c        ****  *   q : quaternion cross-check (attr 287 quat + attr 22 Euler side-by-side) (test 3)
  47:main.c        ****  *   t : exit test   k/x : kill + exit
  48:main.c        ****  *
  49:main.c        ****  * CLI keys — RESET mode:
  50:main.c        ****  *   (automatic: polls attr 382 at 1 Hz, exits when GCU returns 0x00)
  51:main.c        ****  *   x/k : abort reset, return to STANDBY
  52:main.c        ****  *
  53:main.c        ****  * CLI keys — SENSOR mode:
  54:main.c        ****  *   any key : exit to STANDBY
  55:main.c        ****  */
  56:main.c        **** 
