  31:main.c        ****     QX_Msg_t TxMsg;
  32:main.c        ****     QX_InitMsg(&TxMsg);
  33:main.c        **** 
  34:main.c        ****     TxMsg.CommPort = QX_COMMS_PORT_UART;
  35:main.c        ****     TxMsg.Header.Attrib = 277;
  36:main.c        ****     TxMsg.Header.Type = QX_MSG_TYPE_WRITE_ABS;
  37:main.c        ****     TxMsg.Header.Target_Addr = options.Target_Addr;
  38:main.c        ****     TxMsg.Header.TransReq_Addr = options.TransReq_Addr;
  39:main.c        ****     TxMsg.Header.RespReq_Addr = options.RespReq_Addr;
