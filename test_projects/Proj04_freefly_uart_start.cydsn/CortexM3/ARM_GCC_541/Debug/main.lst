  50:main.c        ****     for (uint16_t i = 0; i < TxMsg.MsgBuf_MsgLen; i++)
  51:main.c        ****         out_buf[i] = TxMsg.MsgBufStart_p[i];
  52:main.c        **** 
  53:main.c        ****     *out_len = TxMsg.MsgBuf_MsgLen;
  54:main.c        ****     return 0; // success
  55:main.c        **** }
