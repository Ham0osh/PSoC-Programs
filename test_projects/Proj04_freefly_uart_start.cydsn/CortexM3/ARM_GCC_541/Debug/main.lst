  45:main.c        ****     TxMsg.Parse_Type = QX_PARSE_TYPE_WRITE_ABS_SEND;
  46:main.c        ****     TxMsg.MsgBuf_p = QX_Clients[0].Parser_CB(&TxMsg);
  47:main.c        ****     QX_TxMsg_Finish(&TxMsg);
  48:main.c        **** 
