 423:..\..\FreeflyAPI/QX_Protocol.c **** 		Msg_p->Header.Target_Addr = QX_DEV_ID_BROADCAST;
 424:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 425:..\..\FreeflyAPI/QX_Protocol.c **** 
 426:..\..\FreeflyAPI/QX_Protocol.c **** 	// Add the transmit/response request fields.
 427:..\..\FreeflyAPI/QX_Protocol.c **** 	if (Msg_p->Header.Remove_Req_Fields == 0){
 428:..\..\FreeflyAPI/QX_Protocol.c **** 		QX_AddExtdValToBuf(&Msg_p->MsgBuf_p, Msg_p->Header.TransReq_Addr);
 429:..\..\FreeflyAPI/QX_Protocol.c **** 		QX_AddExtdValToBuf(&Msg_p->MsgBuf_p, Msg_p->Header.RespReq_Addr);
 430:..\..\FreeflyAPI/QX_Protocol.c **** 	} else {
 431:..\..\FreeflyAPI/QX_Protocol.c **** 		Msg_p->Header.TransReq_Addr = QX_DEV_ID_BROADCAST;
 432:..\..\FreeflyAPI/QX_Protocol.c **** 		Msg_p->Header.RespReq_Addr = QX_DEV_ID_BROADCAST;
 433:..\..\FreeflyAPI/QX_Protocol.c **** 	}
