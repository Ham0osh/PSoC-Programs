 235:..\..\FreeflyAPI/QX_Protocol.c **** void QX_Srv_Rx_Write(QX_Msg_t *RxMsg_p)
 236:..\..\FreeflyAPI/QX_Protocol.c **** {
 237:..\..\FreeflyAPI/QX_Protocol.c **** 	// Set parsing type
 238:..\..\FreeflyAPI/QX_Protocol.c **** 	if (RxMsg_p->Header.Type == QX_MSG_TYPE_WRITE_REL){
 239:..\..\FreeflyAPI/QX_Protocol.c **** 		RxMsg_p->Parse_Type = QX_PARSE_TYPE_WRITE_REL_RECV;
