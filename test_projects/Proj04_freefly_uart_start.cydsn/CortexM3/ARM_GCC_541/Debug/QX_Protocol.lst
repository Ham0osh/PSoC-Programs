 213:..\..\FreeflyAPI/QX_Protocol.c **** // Server - Recv Read
 214:..\..\FreeflyAPI/QX_Protocol.c **** // (No data payload) then APP->MSG
 215:..\..\FreeflyAPI/QX_Protocol.c **** void QX_Srv_Rx_Read(QX_Msg_t *RxMsg_p)
 216:..\..\FreeflyAPI/QX_Protocol.c **** {
 217:..\..\FreeflyAPI/QX_Protocol.c **** 	// Check Address - For each server node, if unicast & address match or broadcast, handle it
 218:..\..\FreeflyAPI/QX_Protocol.c **** 	for (int srv_i = 0; srv_i < QX_NUM_SRV; srv_i++){
 219:..\..\FreeflyAPI/QX_Protocol.c **** 		if ((RxMsg_p->Header.Target_Addr == QX_Servers[srv_i].Address) || (RxMsg_p->Header.Target_Addr ==
 220:..\..\FreeflyAPI/QX_Protocol.c **** 			QX_TxMsgOptions_t options;
 221:..\..\FreeflyAPI/QX_Protocol.c **** 			QX_InitTxOptions(&options);
 222:..\..\FreeflyAPI/QX_Protocol.c **** 			options.use_CRC32 = RxMsg_p->Header.AddCRC32;
 223:..\..\FreeflyAPI/QX_Protocol.c **** 			options.FF_Ext = RxMsg_p->Header.FF_Ext;
 224:..\..\FreeflyAPI/QX_Protocol.c **** 			options.Remove_Addr_Fields = RxMsg_p->Header.Remove_Addr_Fields;
 225:..\..\FreeflyAPI/QX_Protocol.c **** 			options.Remove_Req_Fields = 1;		// No need for request fields in a response.
 226:..\..\FreeflyAPI/QX_Protocol.c **** 			options.Target_Addr = RxMsg_p->Header.Source_Addr;		// Reverse target
 227:..\..\FreeflyAPI/QX_Protocol.c **** 			QX_SendPacket_Srv_CurVal(&QX_Servers[srv_i], RxMsg_p->Header.Attrib, RxMsg_p->CommPort, options)
 228:..\..\FreeflyAPI/QX_Protocol.c **** 		}
 229:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 230:..\..\FreeflyAPI/QX_Protocol.c **** }
