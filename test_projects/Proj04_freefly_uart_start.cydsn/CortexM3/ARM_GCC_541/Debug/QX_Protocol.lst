 404:..\..\FreeflyAPI/QX_Protocol.c **** 	OptionByte |= (Msg_p->Header.FF_Ext & 0x01) << 4;
 405:..\..\FreeflyAPI/QX_Protocol.c **** 	OptionByte |= (Msg_p->Header.Remove_Req_Fields & 0x01) << 5;
 406:..\..\FreeflyAPI/QX_Protocol.c **** 	OptionByte |= (Msg_p->Header.Remove_Addr_Fields & 0x01) << 6;
 407:..\..\FreeflyAPI/QX_Protocol.c **** 	OptionByte |= (Msg_p->Header.AddOptionByte1 & 0x01) << 7;
 408:..\..\FreeflyAPI/QX_Protocol.c **** 	*Msg_p->MsgBuf_p++ = OptionByte;
 409:..\..\FreeflyAPI/QX_Protocol.c **** 	
 410:..\..\FreeflyAPI/QX_Protocol.c **** 	// Add option byte 1 if needed
 411:..\..\FreeflyAPI/QX_Protocol.c **** 	if(Msg_p->Header.AddOptionByte1){
 412:..\..\FreeflyAPI/QX_Protocol.c **** 		OptionByte = 0;
 413:..\..\FreeflyAPI/QX_Protocol.c **** 		OptionByte |= (Msg_p->Header.AddCRC32 & 0x01) << 0;
 414:..\..\FreeflyAPI/QX_Protocol.c **** 		*Msg_p->MsgBuf_p++ = OptionByte;
 415:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 416:..\..\FreeflyAPI/QX_Protocol.c **** 	
 417:..\..\FreeflyAPI/QX_Protocol.c **** 	// Add the addresses.
 418:..\..\FreeflyAPI/QX_Protocol.c **** 	if (Msg_p->Header.Remove_Addr_Fields == 0){
 419:..\..\FreeflyAPI/QX_Protocol.c **** 		QX_AddExtdValToBuf(&Msg_p->MsgBuf_p, Msg_p->Header.Source_Addr);
 420:..\..\FreeflyAPI/QX_Protocol.c **** 		QX_AddExtdValToBuf(&Msg_p->MsgBuf_p, Msg_p->Header.Target_Addr);
 421:..\..\FreeflyAPI/QX_Protocol.c **** 	} else {
