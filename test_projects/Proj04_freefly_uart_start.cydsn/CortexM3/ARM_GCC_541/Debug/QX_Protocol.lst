 329:..\..\FreeflyAPI/QX_Protocol.c **** 		
 330:..\..\FreeflyAPI/QX_Protocol.c **** 		// Add padding to get to 4 byte alignment
 331:..\..\FreeflyAPI/QX_Protocol.c **** 		uint32_t bytes_to_add = 4 - ((TxMsg_p->MsgBuf_MsgLen) % 4);		// CRC will bec checked over all byt
 332:..\..\FreeflyAPI/QX_Protocol.c **** 		memset(TxMsg_p->MsgBuf_p, 0, bytes_to_add);		// write zeros to the padding
