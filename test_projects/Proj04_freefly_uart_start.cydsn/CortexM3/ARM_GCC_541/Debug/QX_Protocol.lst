 347:..\..\FreeflyAPI/QX_Protocol.c **** 			TxMsg_p->MsgBuf[1] = 'X';
 348:..\..\FreeflyAPI/QX_Protocol.c **** 			TxMsg_p->MsgBuf[2] = (TxMsg_p->Header.MsgLength & 0x7F) | 0x80;
 349:..\..\FreeflyAPI/QX_Protocol.c **** 			TxMsg_p->MsgBuf[3] = ((TxMsg_p->Header.MsgLength >> 7) & 0x7F);
 350:..\..\FreeflyAPI/QX_Protocol.c **** 		} else {
 351:..\..\FreeflyAPI/QX_Protocol.c **** 			TxMsg_p->MsgBuf[1] = 'Q';
 352:..\..\FreeflyAPI/QX_Protocol.c **** 			TxMsg_p->MsgBuf[2] = 'X';
 353:..\..\FreeflyAPI/QX_Protocol.c **** 			TxMsg_p->MsgBuf[3] = TxMsg_p->Header.MsgLength & 0x7F;
 354:..\..\FreeflyAPI/QX_Protocol.c **** 		}
 355:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 356:..\..\FreeflyAPI/QX_Protocol.c **** 	
 357:..\..\FreeflyAPI/QX_Protocol.c **** 	// Add in the CRC32 if needed
