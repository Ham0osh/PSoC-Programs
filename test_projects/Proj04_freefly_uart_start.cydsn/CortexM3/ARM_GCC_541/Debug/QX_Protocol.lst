 147:..\..\FreeflyAPI/QX_Protocol.c **** QX_Stat_e QX_RxMsg(QX_Msg_t *RxMsg_p)
 148:..\..\FreeflyAPI/QX_Protocol.c **** {
 149:..\..\FreeflyAPI/QX_Protocol.c **** 	RxMsg_p->MsgBuf_p = &RxMsg_p->MsgBuf[0];
 150:..\..\FreeflyAPI/QX_Protocol.c **** 	RxMsg_p->MsgBufStart_p = &RxMsg_p->MsgBuf[0];
 151:..\..\FreeflyAPI/QX_Protocol.c **** 	RxMsg_p->AttNotHandled = 0;		// Assume it will be handled to start - let the parser set this flag 
 152:..\..\FreeflyAPI/QX_Protocol.c **** 	
 153:..\..\FreeflyAPI/QX_Protocol.c **** 	#ifdef QX_DEBUG
 154:..\..\FreeflyAPI/QX_Protocol.c **** 	printf("Raw Msg Packet as Recieved:\n\r");
 155:..\..\FreeflyAPI/QX_Protocol.c **** 	QX_debug_print_Hex(&RxMsg_p->MsgBuf[0], RxMsg_p->Header.MsgLength);
 156:..\..\FreeflyAPI/QX_Protocol.c **** 	#endif
 157:..\..\FreeflyAPI/QX_Protocol.c **** 
 158:..\..\FreeflyAPI/QX_Protocol.c **** 	// Parse Protocol Header
 159:..\..\FreeflyAPI/QX_Protocol.c **** 	if (RxMsg_p->Legacy_Header){
 160:..\..\FreeflyAPI/QX_Protocol.c **** 		if (*QX_ParseHeader_Legacy != NULL){
 161:..\..\FreeflyAPI/QX_Protocol.c **** 			QX_ParseHeader_Legacy(RxMsg_p);
 162:..\..\FreeflyAPI/QX_Protocol.c **** 		} else {
 163:..\..\FreeflyAPI/QX_Protocol.c **** 			return QX_STAT_ERROR;
 164:..\..\FreeflyAPI/QX_Protocol.c **** 		}
 165:..\..\FreeflyAPI/QX_Protocol.c **** 	} else {									
 166:..\..\FreeflyAPI/QX_Protocol.c **** 		QX_ParseHeader(RxMsg_p);
 167:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 168:..\..\FreeflyAPI/QX_Protocol.c **** 	
 169:..\..\FreeflyAPI/QX_Protocol.c **** 	RxMsg_p->BufPayloadStart_p = RxMsg_p->MsgBuf_p;	// the pointer is at the payload after parsing the
 170:..\..\FreeflyAPI/QX_Protocol.c **** 	
 171:..\..\FreeflyAPI/QX_Protocol.c **** 	// Check the CRC32 if enabled
 172:..\..\FreeflyAPI/QX_Protocol.c **** 	if (RxMsg_p->Header.AddCRC32){
 173:..\..\FreeflyAPI/QX_Protocol.c **** 		uint32_t crc32_result = QX_accumulate_crc32(0xFFFFFFFF, RxMsg_p->MsgBuf, RxMsg_p->MsgBuf_MsgLen -
ARM GAS  C:\Users\hamis\AppData\Local\Temp\ccsOK97v.s 			page 5


 174:..\..\FreeflyAPI/QX_Protocol.c **** 		uint32_t crc32_msg = 0;
 175:..\..\FreeflyAPI/QX_Protocol.c **** 		memcpy(&crc32_msg, &RxMsg_p->MsgBuf[RxMsg_p->MsgBuf_MsgLen - 5], sizeof(crc32_msg));
 176:..\..\FreeflyAPI/QX_Protocol.c **** 		if (crc32_result != crc32_msg)
 177:..\..\FreeflyAPI/QX_Protocol.c **** 			return QX_STAT_ERROR_RXMSG_CRC32_FAIL;
 178:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 179:..\..\FreeflyAPI/QX_Protocol.c **** 	
 180:..\..\FreeflyAPI/QX_Protocol.c **** 	// Allow application specific message forwarding (send a copy of the message out one or more other
 181:..\..\FreeflyAPI/QX_Protocol.c **** 	QX_FwdMsg_CB(RxMsg_p);
 182:..\..\FreeflyAPI/QX_Protocol.c **** 	
 183:..\..\FreeflyAPI/QX_Protocol.c **** 	// Print out the recieved packet info for Debug
 184:..\..\FreeflyAPI/QX_Protocol.c **** 	#ifdef QX_DEBUG
 185:..\..\FreeflyAPI/QX_Protocol.c **** 	QX_debug_print_MsgDetails(RxMsg_p);
 186:..\..\FreeflyAPI/QX_Protocol.c **** 	#endif
 187:..\..\FreeflyAPI/QX_Protocol.c **** 	
 188:..\..\FreeflyAPI/QX_Protocol.c **** 	// Handle Eeach type of message
 189:..\..\FreeflyAPI/QX_Protocol.c **** 	switch (RxMsg_p->Header.Type){
 190:..\..\FreeflyAPI/QX_Protocol.c **** 		
 191:..\..\FreeflyAPI/QX_Protocol.c **** 		case QX_MSG_TYPE_READ:
 192:..\..\FreeflyAPI/QX_Protocol.c **** 			QX_Srv_Rx_Read(RxMsg_p);
 193:..\..\FreeflyAPI/QX_Protocol.c **** 			break;
 194:..\..\FreeflyAPI/QX_Protocol.c **** 		
 195:..\..\FreeflyAPI/QX_Protocol.c **** 		case QX_MSG_TYPE_WRITE_ABS:
 196:..\..\FreeflyAPI/QX_Protocol.c **** 		case QX_MSG_TYPE_WRITE_REL:
 197:..\..\FreeflyAPI/QX_Protocol.c **** 			QX_Srv_Rx_Write(RxMsg_p);
 198:..\..\FreeflyAPI/QX_Protocol.c **** 			break;
 199:..\..\FreeflyAPI/QX_Protocol.c **** 		
 200:..\..\FreeflyAPI/QX_Protocol.c **** 		case QX_MSG_TYPE_CURVAL:
 201:..\..\FreeflyAPI/QX_Protocol.c **** 			QX_Cli_Rx_CurVal(RxMsg_p);
 202:..\..\FreeflyAPI/QX_Protocol.c **** 			break;
 203:..\..\FreeflyAPI/QX_Protocol.c **** 		
 204:..\..\FreeflyAPI/QX_Protocol.c **** 		default:
 205:..\..\FreeflyAPI/QX_Protocol.c **** 			return QX_STAT_ERROR_MSG_TYPE_NOT_SUPPORTED;
 206:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 207:..\..\FreeflyAPI/QX_Protocol.c **** 	
 208:..\..\FreeflyAPI/QX_Protocol.c **** 	return QX_STAT_OK;
 209:..\..\FreeflyAPI/QX_Protocol.c **** }
