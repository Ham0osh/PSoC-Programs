 362:..\..\FreeflyAPI/QX_Protocol.c **** 		TxMsg_p->MsgBuf_MsgLen = TxMsg_p->MsgBuf_p - TxMsg_p->MsgBufStart_p;	// Update the overall msg le
 363:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 364:..\..\FreeflyAPI/QX_Protocol.c **** 	
 365:..\..\FreeflyAPI/QX_Protocol.c **** 	// Calculate overall outer checksum
 366:..\..\FreeflyAPI/QX_Protocol.c **** 	uint8_t chksum = QX_Calc8bChecksum(TxMsg_p->MsgBufAtt_p, TxMsg_p->Header.MsgLength);
 367:..\..\FreeflyAPI/QX_Protocol.c **** 	
 368:..\..\FreeflyAPI/QX_Protocol.c **** 	*TxMsg_p->MsgBuf_p++ = 0xFF - chksum;	// Add the Overall Checksum
 369:..\..\FreeflyAPI/QX_Protocol.c **** 	TxMsg_p->MsgBuf_MsgLen++;	// Final message length on the wire
 370:..\..\FreeflyAPI/QX_Protocol.c **** 	
 371:..\..\FreeflyAPI/QX_Protocol.c **** 	#ifdef QX_DEBUG
 372:..\..\FreeflyAPI/QX_Protocol.c **** 	printf("Raw Msg Packet:\n\r");
