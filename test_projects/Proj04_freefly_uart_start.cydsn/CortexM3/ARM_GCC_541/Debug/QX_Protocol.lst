 446:..\..\FreeflyAPI/QX_Protocol.c **** 
 447:..\..\FreeflyAPI/QX_Protocol.c **** 
 448:..\..\FreeflyAPI/QX_Protocol.c **** 	// Get the Extendible Attribute Number
 449:..\..\FreeflyAPI/QX_Protocol.c **** 	Msg_p->Header.Attrib = QX_GetExtdValFromBuf(&Msg_p->MsgBuf_p);
 450:..\..\FreeflyAPI/QX_Protocol.c **** 
 451:..\..\FreeflyAPI/QX_Protocol.c **** 	// Get Base Option Byte Bits
 452:..\..\FreeflyAPI/QX_Protocol.c **** 	OptionByte = *Msg_p->MsgBuf_p++;
