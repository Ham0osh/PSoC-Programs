 439:..\..\FreeflyAPI/QX_Protocol.c **** // Parse a QX Type Message
 440:..\..\FreeflyAPI/QX_Protocol.c **** // Note, this Function leaves the Pointer at the Start of the payload
 441:..\..\FreeflyAPI/QX_Protocol.c **** void QX_ParseHeader(QX_Msg_t *Msg_p)
 442:..\..\FreeflyAPI/QX_Protocol.c **** {
 443:..\..\FreeflyAPI/QX_Protocol.c **** 	volatile uint8_t OptionByte;
 444:..\..\FreeflyAPI/QX_Protocol.c **** 	volatile uint32_t temp32;
