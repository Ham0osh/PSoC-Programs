 387:..\..\FreeflyAPI/QX_Protocol.c **** {
 388:..\..\FreeflyAPI/QX_Protocol.c **** 	// Start at the Attribute Field
 389:..\..\FreeflyAPI/QX_Protocol.c **** 	Msg_p->MsgBuf_p = Msg_p->MsgBufAtt_p;
 390:..\..\FreeflyAPI/QX_Protocol.c **** 
 391:..\..\FreeflyAPI/QX_Protocol.c **** 	// Add the Extendible Attribute Number
 392:..\..\FreeflyAPI/QX_Protocol.c **** 	QX_AddExtdValToBuf(&Msg_p->MsgBuf_p, Msg_p->Header.Attrib);
 393:..\..\FreeflyAPI/QX_Protocol.c **** 
 394:..\..\FreeflyAPI/QX_Protocol.c **** 	Msg_p->Header.AddOptionByte1 = 0;
 395:..\..\FreeflyAPI/QX_Protocol.c **** 	
 396:..\..\FreeflyAPI/QX_Protocol.c **** 	// Check if option byte 1 is needed.
 397:..\..\FreeflyAPI/QX_Protocol.c **** 	if (Msg_p->Header.AddCRC32){
 398:..\..\FreeflyAPI/QX_Protocol.c **** 		Msg_p->Header.AddOptionByte1 = 1;
 399:..\..\FreeflyAPI/QX_Protocol.c **** 	}
 400:..\..\FreeflyAPI/QX_Protocol.c **** 	
 401:..\..\FreeflyAPI/QX_Protocol.c **** 	// Add Base Option Byte
ARM GAS  C:\Users\hamis\AppData\Local\Temp\ccsOK97v.s 			page 10


