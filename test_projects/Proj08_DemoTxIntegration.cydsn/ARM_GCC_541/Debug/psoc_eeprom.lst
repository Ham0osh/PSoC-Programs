  15:psoc_eeprom.c ****  *
  16:psoc_eeprom.c ****  * Generic EEPROM slot store implementation for PSoC 5LP.
  17:psoc_eeprom.c ****  * Uses EEPROM_CONFIG component API:
  18:psoc_eeprom.c ****  *   EEPROM_CONFIG_Start()
  19:psoc_eeprom.c ****  *   EEPROM_CONFIG_UpdateTemperature()
  20:psoc_eeprom.c ****  *   EEPROM_CONFIG_Write(const uint8 *rowData, uint8 rowNumber)
  21:psoc_eeprom.c ****  *   EEPROM_CONFIG_WriteByte(uint8 dataByte, uint16 address)
  22:psoc_eeprom.c ****  * Reading is direct via (uint8 *)(CYDEV_EE_BASE + byte_offset).
  23:psoc_eeprom.c ****  */
  24:psoc_eeprom.c **** 
  25:psoc_eeprom.c **** #include "psoc_eeprom.h"
  26:psoc_eeprom.c **** #include <string.h>
