  23:pi_comms.c    **** extern volatile uint32_t g_tick_ms;  // PSoC ms timer
  24:pi_comms.c    **** 
  25:pi_comms.c    **** // Copied for Pi software codebase
  26:pi_comms.c    **** // We use a Cyclic Redundancy Check (CRC).
  27:pi_comms.c    **** // The CRC takes the whole message as one binary number, divides it by 0x07
  28:pi_comms.c    **** // using XOR operations to be left with the remainder. A table is used instead
  29:pi_comms.c    **** // of computing each of the possible bit-wise division operations.
  30:pi_comms.c    **** static const uint8_t crc8_table[256] = {
  31:pi_comms.c    ****     0x00,0x07,0x0E,0x09,0x1C,0x1B,0x12,0x15,
  32:pi_comms.c    ****     0x38,0x3F,0x36,0x31,0x24,0x23,0x2A,0x2D,
  33:pi_comms.c    ****     0x70,0x77,0x7E,0x79,0x6C,0x6B,0x62,0x65,
  34:pi_comms.c    ****     0x48,0x4F,0x46,0x41,0x54,0x53,0x5A,0x5D,
