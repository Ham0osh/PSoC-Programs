  68:pi_comms.c    **** 
  69:pi_comms.c    **** // Packet parser section enum, initialized to magic byte
  70:pi_comms.c    **** // Expects:
  71:pi_comms.c    **** // [MAGIC] [TYPE] [LEN] ... [PAYLOAD] ... [CRC]
  72:pi_comms.c    **** static enum { S_MAGIC, S_TYPE, S_LEN, S_PAYLOAD, S_CRC } pi_rx_state = S_MAGIC;
  73:pi_comms.c    **** static uint8_t              s_type;  // Type loaded into here
  74:pi_comms.c    **** static uint8_t              s_len;   // Length loaded into here
  75:pi_comms.c    **** static uint8_t              s_idx;
  76:pi_comms.c    **** static uint8_t              s_buf[PI_RX_MAX];  // Payload parsed into here!
  77:pi_comms.c    **** // Per centroid stream
  78:pi_comms.c    **** static payload_centroid_t   s_centroid[STREAM_COUNTS];  // Payload per centroid
  79:pi_comms.c    **** static volatile uint8_t     s_fresh_bits;  // bit 0 for coarse and 1 for fine
  80:pi_comms.c    **** static uint32_t             s_last_rx_ms[STREAM_COUNTS];
  81:pi_comms.c    **** static uint16_t             s_last_centroid_dt_ms[STREAM_COUNTS];
  82:pi_comms.c    **** // Global telemetry for communications.
  83:pi_comms.c    **** static uint16_t s_crc_err             = 0u;  // inter-device communications.
  84:pi_comms.c    **** static uint16_t s_uart_err            = 0u;
  85:pi_comms.c    **** static uint16_t s_unknown_magic       = 0u;
  86:pi_comms.c    **** static uint32_t s_rx_pkt_count        = 0u;
  87:pi_comms.c    **** 
