  36:pi_comms.c    ****     0xD8,0xDF,0xD6,0xD1,0xC4,0xC3,0xCA,0xCD,
  37:pi_comms.c    ****     0x90,0x97,0x9E,0x99,0x8C,0x8B,0x82,0x85,
  38:pi_comms.c    ****     0xA8,0xAF,0xA6,0xA1,0xB4,0xB3,0xBA,0xBD,
  39:pi_comms.c    ****     0xC7,0xC0,0xC9,0xCE,0xDB,0xDC,0xD5,0xD2,
