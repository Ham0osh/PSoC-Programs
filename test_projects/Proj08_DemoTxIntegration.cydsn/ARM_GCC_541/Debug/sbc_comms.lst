  69:sbc_comms.c   **** // Packet parser section enum, initialized to magic byte
  70:sbc_comms.c   **** // Expects: [MAGIC] [TYPE] [LEN] ... [PAYLOAD] ... [CRC]
  71:sbc_comms.c   **** static enum { S_MAGIC, S_TYPE, S_LEN, S_PAYLOAD, S_CRC } sbc_rx_state = S_MAGIC;
  72:sbc_comms.c   **** 
  73:sbc_comms.c   **** // Variables that packets are loaded into plus flag for "newer" write.
  74:sbc_comms.c   **** static uint8_t              s_type;  // Type loaded into here
  75:sbc_comms.c   **** static uint8_t              s_len;   // Length loaded into here
  76:sbc_comms.c   **** static uint8_t              s_idx;
  77:sbc_comms.c   **** static uint8_t              s_buf[SBC_RX_MAX];  // Payload parsed into here!
  78:sbc_comms.c   **** // Per centroid stream
  79:sbc_comms.c   **** static payload_centroid_t   s_centroid[STREAM_COUNTS];  // Payload per centroid
  80:sbc_comms.c   **** static volatile uint8_t     s_fresh_bits;  // bit 0 for coarse and bit 1 for fine
