  77:app_statemachine.c ****     [STBY_DEFER]      = STBY,  // Two types of standby
  78:app_statemachine.c ****     [STBY_HOLD]       = STBY,  // Hold and wait
  79:app_statemachine.c **** 
  80:app_statemachine.c ****     [MANU_JOYSTICK]   = MANU,
  81:app_statemachine.c **** 
  82:app_statemachine.c ****     [AUTO_HOME]       = AUTO,  // Go to 0, 0
  83:app_statemachine.c ****     [AUTO_HOLD]       = AUTO,  // Hold but accept centroids
  84:app_statemachine.c ****     [AUTO_ACQ_GPS]    = AUTO,  // Go to GPS vector pointing
  85:app_statemachine.c ****     [AUTO_ACQ_SPIRAL] = AUTO,  // Spiral search for lock
  86:app_statemachine.c ****     [AUTO_TRACKING]   = AUTO,  // Closed loop tracking
  87:app_statemachine.c ****     [AUTO_LOSS]       = AUTO,  // Loss of centeroiding packets
  88:app_statemachine.c ****     [AUTO_NO_LOCK]    = AUTO,  // No lock after ACQ attempts
  89:app_statemachine.c **** 
  90:app_statemachine.c ****     [ERROR_ACTIVE]    = ERROR,  // Error state. TODO: Severity levels.
  91:app_statemachine.c ****     [ERROR_KILL]      = ERROR,  // Sends kill to gimbal.
  92:app_statemachine.c **** };
