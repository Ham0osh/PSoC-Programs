  38:sbc_comms.c   ****     0x90,0x97,0x9E,0x99,0x8C,0x8B,0x82,0x85,
  39:sbc_comms.c   ****     0xA8,0xAF,0xA6,0xA1,0xB4,0xB3,0xBA,0xBD,
  40:sbc_comms.c   ****     0xC7,0xC0,0xC9,0xCE,0xDB,0xDC,0xD5,0xD2,
