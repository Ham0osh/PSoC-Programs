  68:sbc_comms.c   **** // Packet parser section enum, initialized to magic byte
  69:sbc_comms.c   **** // Expects:
  70:sbc_comms.c   **** // [MAGIC] [TYPE] [LEN] ... [PAYLOAD] ... [CRC]
  71:sbc_comms.c   **** static enum { S_MAGIC, S_TYPE, S_LEN, S_PAYLOAD, S_CRC } sbc_rx_state = S_MAGIC;
  72:sbc_comms.c   **** static uint8_t              s_type;  // Type loaded into here
  73:sbc_comms.c   **** static uint8_t              s_len;   // Length loaded into here
  74:sbc_comms.c   **** static uint8_t              s_idx;
  75:sbc_comms.c   **** static uint8_t              s_buf[SBC_RX_MAX];  // Payload parsed into here!
  76:sbc_comms.c   **** // Per centroid stream
  77:sbc_comms.c   **** static payload_centroid_t   s_centroid[STREAM_COUNTS];  // Payload per centroid
  78:sbc_comms.c   **** static volatile uint8_t     s_fresh_bits;  // bit 0 for coarse and bit 1 for fine
  79:sbc_comms.c   **** static uint32_t             s_last_rx_ms[STREAM_COUNTS];
  80:sbc_comms.c   **** static uint16_t             s_last_centroid_dt_ms[STREAM_COUNTS];
  81:sbc_comms.c   **** // Global telemetry for communications.
  82:sbc_comms.c   **** static uint16_t s_crc_err             = 0u;  // inter-device communications.
  83:sbc_comms.c   **** static uint16_t s_uart_err            = 0u;
  84:sbc_comms.c   **** static uint16_t s_unknown_magic       = 0u;
  85:sbc_comms.c   **** static uint32_t s_rx_pkt_count        = 0u;
