  69:app_statemachine.c **** 
  70:app_statemachine.c ****     [AUTO_HOME]       = AUTO,
  71:app_statemachine.c ****     [AUTO_ACQ_GPS]    = AUTO,
  72:app_statemachine.c ****     [AUTO_ACQ_SPIRAL] = AUTO,
  73:app_statemachine.c ****     [AUTO_TRACKING]   = AUTO,
  74:app_statemachine.c ****     [AUTO_LOSS]       = AUTO,
  75:app_statemachine.c ****     [AUTO_NO_LOCK]    = AUTO,
  76:app_statemachine.c **** 
