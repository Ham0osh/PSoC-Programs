  52:app_statemachine.c **** // Hierarchy %================================================================%
  53:app_statemachine.c **** // Heirarchy allows shared entry/exit behaviour.
  54:app_statemachine.c **** // ROOT is the base of the walk.
  55:app_statemachine.c **** static const state_t parent_of[STATE_COUNT] = {
  56:app_statemachine.c ****     [ROOT]            = ROOT,  // Book keeping
  57:app_statemachine.c ****     [STBY]            = ROOT,  // Parent states
  58:app_statemachine.c ****     [MANU]            = ROOT,
  59:app_statemachine.c ****     [AUTO]            = ROOT,
  60:app_statemachine.c ****     [ERROR]           = ROOT,
  61:app_statemachine.c **** 
  62:app_statemachine.c ****     [STBY_DEFER]      = STBY,
  63:app_statemachine.c ****     [STBY_HOLD]       = STBY,
  64:app_statemachine.c **** 
  65:app_statemachine.c ****     [MANU_JOYSTICK]   = MANU,
  66:app_statemachine.c ****     [MANU_NUDGE]      = MANU,
  67:app_statemachine.c **** 
  68:app_statemachine.c ****     [AUTO_HOME]       = AUTO,
  69:app_statemachine.c ****     [AUTO_ACQ_GPS]    = AUTO,
  70:app_statemachine.c ****     [AUTO_ACQ_SPIRAL] = AUTO,
  71:app_statemachine.c ****     [AUTO_TRACKING]   = AUTO,
  72:app_statemachine.c ****     [AUTO_LOSS]       = AUTO,
  73:app_statemachine.c ****     [AUTO_NO_LOCK]    = AUTO,
  74:app_statemachine.c **** 
  75:app_statemachine.c ****     [ERROR_ACTIVE]    = ERROR,
  76:app_statemachine.c **** };
  77:app_statemachine.c **** 
