  53:app_statemachine.c **** 
  54:app_statemachine.c **** // Hierarchy %================================================================%
  55:app_statemachine.c **** // Heirarchy allows shared entry/exit behaviour.
  56:app_statemachine.c **** // ROOT is the base of the walk.
  57:app_statemachine.c **** static const state_t parent_of[STATE_COUNT] = {
  58:app_statemachine.c ****     [ROOT]            = ROOT,  // Book keeping
  59:app_statemachine.c ****     [STBY]            = ROOT,  // Parent states
  60:app_statemachine.c ****     [MANU]            = ROOT,
  61:app_statemachine.c ****     [AUTO]            = ROOT,
  62:app_statemachine.c ****     [ERROR]           = ROOT,
  63:app_statemachine.c **** 
  64:app_statemachine.c ****     [STBY_DEFER]      = STBY,  // Two types of standby
  65:app_statemachine.c ****     [STBY_HOLD]       = STBY,
  66:app_statemachine.c **** 
  67:app_statemachine.c ****     [MANU_JOYSTICK]   = MANU,  // TODO: Fold into one manual state with both active.
  68:app_statemachine.c ****     [MANU_NUDGE]      = MANU,  //       Currently nudge works during joystick.
  69:app_statemachine.c **** 
  70:app_statemachine.c ****     [AUTO_HOME]       = AUTO,  // Go to 0, 0
  71:app_statemachine.c ****     [AUTO_ACQ_GPS]    = AUTO,  // Go to GPS vector pointing
  72:app_statemachine.c ****     [AUTO_ACQ_SPIRAL] = AUTO,  // Spiral search for lock
  73:app_statemachine.c ****     [AUTO_TRACKING]   = AUTO,  // Closed loop tracking
  74:app_statemachine.c ****     [AUTO_LOSS]       = AUTO,  // Loss of centeroiding packets
  75:app_statemachine.c ****     [AUTO_NO_LOCK]    = AUTO,  // No lock after ACQ attempts
  76:app_statemachine.c **** 
  77:app_statemachine.c ****     [ERROR_ACTIVE]    = ERROR,  // Error state. TODO: Severity levels.
  78:app_statemachine.c **** };
  79:app_statemachine.c **** 
