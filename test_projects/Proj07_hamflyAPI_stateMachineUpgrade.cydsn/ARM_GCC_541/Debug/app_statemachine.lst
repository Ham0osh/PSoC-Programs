  58:app_statemachine.c ****     [ROOT]            = ROOT,  // Book keeping
  59:app_statemachine.c ****     [STBY]            = ROOT,  // Parent states
  60:app_statemachine.c ****     [MANU]            = ROOT,
  61:app_statemachine.c ****     [AUTO]            = ROOT,
  62:app_statemachine.c ****     [ERROR]           = ROOT,
  63:app_statemachine.c **** 
  64:app_statemachine.c ****     [STBY_DEFER]      = STBY,
