  77:app_statemachine.c ****     [STBY_HOLD]       = STBY,  // Hold and wait
  78:app_statemachine.c **** 
  79:app_statemachine.c ****     [MANU_JOYSTICK]   = MANU,
  80:app_statemachine.c **** 
  81:app_statemachine.c ****     [AUTO_HOME]       = AUTO,  // Go to 0, 0
  82:app_statemachine.c ****     [AUTO_HOLD]       = AUTO,  // Hold but accept centroids
  83:app_statemachine.c ****     [AUTO_ACQ_GPS]    = AUTO,  // Go to GPS vector pointing
  84:app_statemachine.c ****     [AUTO_ACQ_SPIRAL] = AUTO,  // Spiral search for lock
  85:app_statemachine.c ****     [AUTO_TRACKING]   = AUTO,  // Closed loop tracking
  86:app_statemachine.c ****     [AUTO_LOSS]       = AUTO,  // Loss of centeroiding packets
  87:app_statemachine.c ****     [AUTO_NO_LOCK]    = AUTO,  // No lock after ACQ attempts
  88:app_statemachine.c **** 
  89:app_statemachine.c ****     [ERROR_ACTIVE]    = ERROR,  // Error state. TODO: Severity levels.
  90:app_statemachine.c ****     [ERROR_KILL]      = ERROR,  // Sends kill to gimbal.
  91:app_statemachine.c **** };
