  66:app_statemachine.c **** // Hierarchy %================================================================%
  67:app_statemachine.c **** // Heirarchy allows shared entry/exit behaviour.
  68:app_statemachine.c **** // ROOT is the base of the walk.
  69:app_statemachine.c **** static const state_t parent_of[STATE_COUNT] = {
  70:app_statemachine.c ****     [ROOT]            = ROOT,  // Book keeping
  71:app_statemachine.c ****     [STBY]            = ROOT,  // Parent states
  72:app_statemachine.c ****     [MANU]            = ROOT,
  73:app_statemachine.c ****     [AUTO]            = ROOT,
  74:app_statemachine.c ****     [ERROR]           = ROOT,
  75:app_statemachine.c **** 
  76:app_statemachine.c ****     [STBY_DEFER]      = STBY,  // Two types of standby
