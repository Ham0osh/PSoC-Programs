  51:app_statemachine.c **** // Hierarchy %================================================================%
  52:app_statemachine.c **** // Heirarchy allows shared entry/exit behaviour.
  53:app_statemachine.c **** // ROOT is the base of the walk.
  54:app_statemachine.c **** static const state_t parent_of[STATE_COUNT] = {
  55:app_statemachine.c ****     [ROOT]            = ROOT,  // Book keeping
  56:app_statemachine.c ****     [STBY]            = ROOT,  // Parent states
  57:app_statemachine.c ****     [MANU]            = ROOT,
  58:app_statemachine.c ****     [AUTO]            = ROOT,
  59:app_statemachine.c ****     [ERROR]           = ROOT,
  60:app_statemachine.c **** 
  61:app_statemachine.c ****     [STBY_DEFER]      = STBY,
  62:app_statemachine.c ****     [STBY_HOLD]       = STBY,
  63:app_statemachine.c **** 
  64:app_statemachine.c ****     [MANU_JOYSTICK]   = MANU,
  65:app_statemachine.c ****     [MANU_NUDGE]      = MANU,
  66:app_statemachine.c **** 
  67:app_statemachine.c ****     [AUTO_HOME]       = AUTO,
  68:app_statemachine.c ****     [AUTO_ACQ_GPS]    = AUTO,
  69:app_statemachine.c ****     [AUTO_ACQ_SPIRAL] = AUTO,
  70:app_statemachine.c ****     [AUTO_TRACKING]   = AUTO,
  71:app_statemachine.c ****     [AUTO_LOSS]       = AUTO,
  72:app_statemachine.c ****     [AUTO_NO_LOCK]    = AUTO,
  73:app_statemachine.c **** 
  74:app_statemachine.c ****     [ERROR_ACTIVE]    = ERROR,
  75:app_statemachine.c **** };
