  66:app_statemachine.c **** // Hierarchy %================================================================%
  67:app_statemachine.c **** // Heirarchy allows shared entry/exit behaviour.
  68:app_statemachine.c **** // ROOT is the base of the walk.
  69:app_statemachine.c **** static const state_t parent_of[STATE_COUNT] = {
  70:app_statemachine.c ****     [ROOT]            = ROOT,  // Book keeping
  71:app_statemachine.c ****     [STBY]            = ROOT,  // Parent states
  72:app_statemachine.c ****     [MANU]            = ROOT,
  73:app_statemachine.c ****     [AUTO]            = ROOT,
  74:app_statemachine.c ****     [ERROR]           = ROOT,
  75:app_statemachine.c **** 
  76:app_statemachine.c ****     [STBY_DEFER]      = STBY,  // Two types of standby
  77:app_statemachine.c ****     [STBY_HOLD]       = STBY,
  78:app_statemachine.c **** 
  79:app_statemachine.c ****     [MANU_JOYSTICK]   = MANU,
  80:app_statemachine.c **** 
  81:app_statemachine.c ****     [AUTO_HOME]       = AUTO,  // Go to 0, 0
  82:app_statemachine.c ****     [AUTO_ACQ_GPS]    = AUTO,  // Go to GPS vector pointing
  83:app_statemachine.c ****     [AUTO_ACQ_SPIRAL] = AUTO,  // Spiral search for lock
  84:app_statemachine.c ****     [AUTO_TRACKING]   = AUTO,  // Closed loop tracking
  85:app_statemachine.c ****     [AUTO_LOSS]       = AUTO,  // Loss of centeroiding packets
  86:app_statemachine.c ****     [AUTO_NO_LOCK]    = AUTO,  // No lock after ACQ attempts
  87:app_statemachine.c **** 
  88:app_statemachine.c ****     [ERROR_ACTIVE]    = ERROR,  // Error state. TODO: Severity levels.
  89:app_statemachine.c **** };
