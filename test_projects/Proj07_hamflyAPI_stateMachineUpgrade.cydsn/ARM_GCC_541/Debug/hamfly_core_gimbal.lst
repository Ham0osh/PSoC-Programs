 335:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** // Hamfly Write Attribute U8: Request write of an attr ID with a single byte.
 336:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** // Handles single and two-byte varints for the attr ID by bypassing the QX
 337:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** // state machine and building the packet directly into the txbuf.
 338:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** // This is an extension, not part of the FreeflyAPI.
 339:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** //
 340:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** // Example usecases:
 341:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** //  - Request write of 0x01 to 382 to reset the heading.
 342:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** //  - Request write of a two-byte varint attr like 0x80 (set gimbal ID).
 343:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** //  
 344:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** // Issues:
 345:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** //  - Many of these are unconfirmed and only exist due to BLE sniffing.
 346:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** //  - Some appear to need more bytes, so moving to an array of bytes is needed. 
 347:..\..\..\HamFlyAPI\src/hamfly_core_gimbal.c **** // ============================================================================
