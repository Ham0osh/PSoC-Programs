   2:main.c        ****  * Author: Hamish Johnson
   3:main.c        ****  * Org: Quantum Internet Systems Lab, SFU, Physics
   4:main.c        ****  * Date: March 2026
   5:main.c        ****  *
   6:main.c        ****  * Uses HamflyAPI (hamfly.h) for all gimbal communication.
   7:main.c        ****  *
   8:main.c        ****  * Modes:
   9:main.c        ****  *   STANDBY   passive; pump runs; 1 Hz status if telemetry valid.
  10:main.c        ****  *             Set boresight origin here before entering other modes.
  11:main.c        ****  *   JOYSTICK  10 Hz QX277 TX.  Joystick (rate) and numpad presets
  12:main.c        ****  *             share the mode — preset executes, settles to within
  13:main.c        ****  *             PRESET_SETTLE_DEG of target (or PRESET_SETTLE_MS
  14:main.c        ****  *             timeout), then joystick resumes automatically.
  15:main.c        ****  *   NUDGE     keyboard-driven absolute accumulation for beam-profiler
  16:main.c        ****  *             calibration.  Each keypress adds a fixed step to the
  17:main.c        ****  *             accumulated pan/tilt target, clamped to software limits.
  18:main.c        ****  *             Current accumulated position prints after every step.
  19:main.c        ****  *             No joystick input in this mode.
  20:main.c        ****  *
  21:main.c        ****  *   t  exit to STANDBY     
  22:main.c        ****  *   x  kill + exit
  23:main.c        ****  */
  24:main.c        **** 
  25:main.c        **** #include <project.h>
  26:main.c        **** #include <stdio.h>
  27:main.c        **** #include <math.h>
  28:main.c        **** #include <string.h>
  29:main.c        **** 
  30:main.c        **** // Gimbal stuff
  31:main.c        **** #include "hamfly.h"
  32:main.c        **** #include "hamfly_platform_psoc5.h"
  33:main.c        **** 
  34:main.c        **** // Implementation specific stuff
  35:main.c        **** #include "adc_balanced.h"
  36:main.c        **** #include "joystick.h"
  37:main.c        **** 
  38:main.c        **** // PSoC state machine stuff
  39:main.c        **** #include "psoc_eeprom.h"
  40:main.c        **** #include "app_ctx.h"
  41:main.c        **** #include "app_statemachine.h"
  42:main.c        **** 
  43:main.c        **** // Timing constants
  44:main.c        **** #define TX_BUF_SIZE           160u
  45:main.c        **** #define CONTROL_PERIOD_MS     100u   // 10 Hz control TX
  46:main.c        **** #define DIAG_PERIOD_MS        1000u  // 1 Hz diagnostic print
  47:main.c        **** #define QUERY_TIMEOUT_MS      2000u  // max wait for attr response in QUERY
  48:main.c        **** 
  49:main.c        **** // Soft limits relative to origin (degrees)
  50:main.c        **** // Origin set by pressing '[' in any mode
  51:main.c        **** #define LIMIT_PAN_MAX_DEG      30.0f
  52:main.c        **** #define LIMIT_PAN_MIN_DEG     -30.0f
  53:main.c        **** #define LIMIT_TILT_MAX_DEG     20.0f
  54:main.c        **** #define LIMIT_TILT_MIN_DEG    -20.0f
  55:main.c        **** 
  56:main.c        **** // Nudge config
  57:main.c        **** #define NUDGE_RATE              0.5f
  58:main.c        **** #define NUDGE_TIME_SMALL        50u   // ms
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccYYdK9f.s 			page 4


  59:main.c        **** #define NUDGE_TIME_LARGE        200u  // ms
  60:main.c        **** 
  61:main.c        **** // Utilities
  62:main.c        **** #define DEG_TO_UNIT(d)   ((float)(d) / 180.0f)
  63:main.c        **** #define UNIT_TO_DEG(u)   ((float)(u) * 180.0f)
  64:main.c        **** #define CLAMP(v,lo,hi)   ((v)<(lo)?(lo):((v)>(hi)?(hi):(v)))
  65:main.c        **** #define FALSE  0u
  66:main.c        **** #define TRUE   1u
