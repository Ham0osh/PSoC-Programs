  65:..\..\..\HamFlyAPI\src/hamfly_core_telemetry.c **** // FreeflyAPI Euler convention (pan = yaw about Z, tilt = pitch about Y,
  66:..\..\..\HamFlyAPI\src/hamfly_core_telemetry.c **** // roll = rotation about X).
