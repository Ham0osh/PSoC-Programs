 255:..\..\..\HamFlyAPI\src/hamfly_core_telemetry.c **** // off 13-14 BE int16:  camera status
 256:..\..\..\HamFlyAPI\src/hamfly_core_telemetry.c **** // off 15    uint8:     reserved
 257:..\..\..\HamFlyAPI\src/hamfly_core_telemetry.c **** // off 16-17 BE int16:  IMU latency          us
