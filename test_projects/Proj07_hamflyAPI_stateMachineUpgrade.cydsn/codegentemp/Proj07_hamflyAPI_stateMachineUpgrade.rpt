              \UART_SBC:BUART:rx_state_0\ * !\UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:rx_count_6\ * 
              !\UART_SBC:BUART:rx_count_4\
        );
        Output = \UART_SBC:BUART:rx_state_0\ (fanout=8)

    MacroCell: Name=\UART_SBC:BUART:rx_load_fifo\, Mode=(D-Register)
        Total # of inputs        : 8
        Total # of product terms : 3
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 3 pterms
        (
              !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              !\UART_SBC:BUART:rx_state_0\ * 
              \UART_SBC:BUART:rx_bitclk_enable\ * \UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              \UART_SBC:BUART:rx_state_0\ * !\UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:rx_count_6\ * 
              !\UART_SBC:BUART:rx_count_5\
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              \UART_SBC:BUART:rx_state_0\ * !\UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:rx_count_6\ * 
              !\UART_SBC:BUART:rx_count_4\
        );
        Output = \UART_SBC:BUART:rx_load_fifo\ (fanout=2)

    MacroCell: Name=\UART_SBC:BUART:rx_state_3\, Mode=(T-Register)
        Total # of inputs        : 8
        Total # of product terms : 3
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 3 pterms
        (
              !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              !\UART_SBC:BUART:rx_state_0\ * 
              \UART_SBC:BUART:rx_bitclk_enable\ * \UART_SBC:BUART:rx_state_3\ * 
              \UART_SBC:BUART:rx_state_2\
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              \UART_SBC:BUART:rx_state_0\ * !\UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:rx_count_6\ * 
              !\UART_SBC:BUART:rx_count_5\
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              \UART_SBC:BUART:rx_state_0\ * !\UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:rx_count_6\ * 
              !\UART_SBC:BUART:rx_count_4\
        );
        Output = \UART_SBC:BUART:rx_state_3\ (fanout=7)

    MacroCell: Name=\UART_SBC:BUART:rx_state_2\, Mode=(T-Register)
        Total # of inputs        : 10
        Total # of product terms : 5
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 5 pterms
        (
              !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              !\UART_SBC:BUART:rx_state_0\ * 
              \UART_SBC:BUART:rx_bitclk_enable\ * \UART_SBC:BUART:rx_state_3\
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              !\UART_SBC:BUART:rx_state_0\ * 
              \UART_SBC:BUART:rx_bitclk_enable\ * \UART_SBC:BUART:rx_state_2\
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              !\UART_SBC:BUART:rx_state_0\ * !\UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\ * !Net_464 * 
              \UART_SBC:BUART:rx_last\
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              \UART_SBC:BUART:rx_state_0\ * !\UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:rx_count_6\ * 
              !\UART_SBC:BUART:rx_count_5\
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              \UART_SBC:BUART:rx_state_0\ * !\UART_SBC:BUART:rx_state_3\ * 
              !\UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:rx_count_6\ * 
              !\UART_SBC:BUART:rx_count_4\
        );
        Output = \UART_SBC:BUART:rx_state_2\ (fanout=7)

    MacroCell: Name=\UART_SBC:BUART:rx_bitclk_enable\, Mode=(D-Register)
        Total # of inputs        : 3
        Total # of product terms : 1
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              !\UART_SBC:BUART:rx_count_2\ * !\UART_SBC:BUART:rx_count_1\ * 
              !\UART_SBC:BUART:rx_count_0\
        );
        Output = \UART_SBC:BUART:rx_bitclk_enable\ (fanout=6)

    MacroCell: Name=\UART_SBC:BUART:rx_state_stop1_reg\, Mode=(D-Register)
        Total # of inputs        : 4
        Total # of product terms : 1
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 1 pterm
        !(
              !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              !\UART_SBC:BUART:rx_state_0\ * \UART_SBC:BUART:rx_state_3\ * 
              \UART_SBC:BUART:rx_state_2\
        );
        Output = \UART_SBC:BUART:rx_state_stop1_reg\ (fanout=1)

    MacroCell: Name=\UART_SBC:BUART:pollcount_1\, Mode=(D-Register)
        Total # of inputs        : 5
        Total # of product terms : 3
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 3 pterms
        (
              !\UART_SBC:BUART:rx_count_2\ * !\UART_SBC:BUART:rx_count_1\ * 
              !\UART_SBC:BUART:pollcount_1\ * Net_464 * 
              \UART_SBC:BUART:pollcount_0\
            + !\UART_SBC:BUART:rx_count_2\ * !\UART_SBC:BUART:rx_count_1\ * 
              \UART_SBC:BUART:pollcount_1\ * !Net_464
            + !\UART_SBC:BUART:rx_count_2\ * !\UART_SBC:BUART:rx_count_1\ * 
              \UART_SBC:BUART:pollcount_1\ * !\UART_SBC:BUART:pollcount_0\
        );
        Output = \UART_SBC:BUART:pollcount_1\ (fanout=4)

    MacroCell: Name=\UART_SBC:BUART:pollcount_0\, Mode=(D-Register)
        Total # of inputs        : 4
        Total # of product terms : 2
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 2 pterms
        (
              !\UART_SBC:BUART:rx_count_2\ * !\UART_SBC:BUART:rx_count_1\ * 
              !Net_464 * \UART_SBC:BUART:pollcount_0\
            + !\UART_SBC:BUART:rx_count_2\ * !\UART_SBC:BUART:rx_count_1\ * 
              Net_464 * !\UART_SBC:BUART:pollcount_0\
        );
        Output = \UART_SBC:BUART:pollcount_0\ (fanout=5)

    MacroCell: Name=\UART_SBC:BUART:rx_status_3\, Mode=(D-Register)
        Total # of inputs        : 8
        Total # of product terms : 2
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 2 pterms
        (
              !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              !\UART_SBC:BUART:rx_state_0\ * 
              \UART_SBC:BUART:rx_bitclk_enable\ * \UART_SBC:BUART:rx_state_3\ * 
              \UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:pollcount_1\ * 
              !Net_464
            + !\UART_SBC:BUART:tx_ctrl_mark_last\ * 
              !\UART_SBC:BUART:rx_state_0\ * 
              \UART_SBC:BUART:rx_bitclk_enable\ * \UART_SBC:BUART:rx_state_3\ * 
              \UART_SBC:BUART:rx_state_2\ * !\UART_SBC:BUART:pollcount_1\ * 
              !\UART_SBC:BUART:pollcount_0\
        );
        Output = \UART_SBC:BUART:rx_status_3\ (fanout=1)

    MacroCell: Name=\UART_SBC:BUART:rx_last\, Mode=(D-Register)
        Total # of inputs        : 1
        Total # of product terms : 1
        List of special equations: 
            Clock  = (\UART_SBC:Net_9\) => Global
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              Net_464
        );
        Output = \UART_SBC:BUART:rx_last\ (fanout=1)
