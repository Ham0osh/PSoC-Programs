    <CYPRESSTAG name="Macrocell listing" icon="FILE_RPT_EQUATION">

    ------------------------------------------------------------
    Macrocell listing
    ------------------------------------------------------------

    MacroCell: Name=Net_394, Mode=(Combinatorial)
        Total # of inputs        : 1
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              !\UART_MOVI:BUART:txn\
        );
        Output = Net_394 (fanout=2)

    MacroCell: Name=\UART_MOVI:BUART:counter_load_not\, Mode=(Combinatorial)
        Total # of inputs        : 4
        Total # of product terms : 2
            Clock Enable: True
        Main Equation            : 2 pterms
        !(
              !\UART_MOVI:BUART:tx_state_1\ * !\UART_MOVI:BUART:tx_state_0\ * 
              \UART_MOVI:BUART:tx_bitclk_enable_pre\
            + !\UART_MOVI:BUART:tx_state_1\ * !\UART_MOVI:BUART:tx_state_0\ * 
              !\UART_MOVI:BUART:tx_state_2\
        );
        Output = \UART_MOVI:BUART:counter_load_not\ (fanout=1)

    MacroCell: Name=\UART_MOVI:BUART:tx_status_0\, Mode=(Combinatorial)
        Total # of inputs        : 5
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              !\UART_MOVI:BUART:tx_state_1\ * !\UART_MOVI:BUART:tx_state_0\ * 
              \UART_MOVI:BUART:tx_bitclk_enable_pre\ * 
              \UART_MOVI:BUART:tx_fifo_empty\ * \UART_MOVI:BUART:tx_state_2\
        );
        Output = \UART_MOVI:BUART:tx_status_0\ (fanout=1)

    MacroCell: Name=\UART_MOVI:BUART:tx_status_2\, Mode=(Combinatorial)
        Total # of inputs        : 1
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              !\UART_MOVI:BUART:tx_fifo_notfull\
        );
        Output = \UART_MOVI:BUART:tx_status_2\ (fanout=1)

    MacroCell: Name=\UART_MOVI:BUART:rx_counter_load\, Mode=(Combinatorial)
        Total # of inputs        : 4
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              !\UART_MOVI:BUART:tx_ctrl_mark_last\ * 
              !\UART_MOVI:BUART:rx_state_0\ * !\UART_MOVI:BUART:rx_state_3\ * 
              !\UART_MOVI:BUART:rx_state_2\
        );
        Output = \UART_MOVI:BUART:rx_counter_load\ (fanout=1)

    MacroCell: Name=\UART_MOVI:BUART:rx_postpoll\, Mode=(Combinatorial)
        Total # of inputs        : 3
        Total # of product terms : 2
            Clock Enable: True
        Main Equation            : 2 pterms
        (
              Net_369 * MODIN1_0
            + MODIN1_1
        );
        Output = \UART_MOVI:BUART:rx_postpoll\ (fanout=1)

    MacroCell: Name=\UART_MOVI:BUART:rx_status_4\, Mode=(Combinatorial)
        Total # of inputs        : 2
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              \UART_MOVI:BUART:rx_load_fifo\ * \UART_MOVI:BUART:rx_fifofull\
        );
        Output = \UART_MOVI:BUART:rx_status_4\ (fanout=1)

    MacroCell: Name=\UART_MOVI:BUART:rx_status_5\, Mode=(Combinatorial)
        Total # of inputs        : 2
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              \UART_MOVI:BUART:rx_fifonotempty\ * 
              \UART_MOVI:BUART:rx_state_stop1_reg\
        );
        Output = \UART_MOVI:BUART:rx_status_5\ (fanout=1)

    MacroCell: Name=Net_436, Mode=(Combinatorial)
        Total # of inputs        : 1
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              !\UART_SBC:BUART:txn\
        );
        Output = Net_436 (fanout=1)

    MacroCell: Name=\UART_SBC:BUART:counter_load_not\, Mode=(Combinatorial)
        Total # of inputs        : 4
        Total # of product terms : 2
            Clock Enable: True
        Main Equation            : 2 pterms
        !(
              !\UART_SBC:BUART:tx_state_1\ * !\UART_SBC:BUART:tx_state_0\ * 
              \UART_SBC:BUART:tx_bitclk_enable_pre\
            + !\UART_SBC:BUART:tx_state_1\ * !\UART_SBC:BUART:tx_state_0\ * 
