set_io "Pin_Debug_SuperLoop(0)" iocell 3 1
set_io "Pin_Debug_CoarseCentroid(0)" iocell 3 2
set_io "Pin_Debug_GimbalComms(0)" iocell 3 3
set_io "Pin_Debug_SBCComms(0)" iocell 3 4
