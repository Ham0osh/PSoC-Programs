              \UART_SBC:BUART:tx_bitclk_enable_pre\ * 
              \UART_SBC:BUART:tx_fifo_empty\ * \UART_SBC:BUART:tx_state_2\
            + \UART_SBC:BUART:tx_state_0\ * !\UART_SBC:BUART:tx_state_2\ * 
