 113:main.c        ****     APP_MODE_STANDBY = 0,
 114:main.c        ****     APP_MODE_CONTROL,      /* joystick rate + numpad presets                   */
 115:main.c        ****     APP_MODE_QUERY,        /* one-shot attr reads, verbose print                */
 116:main.c        ****     APP_MODE_NUDGE,        /* keyboard abs-accumulation for beam calibration    */
 117:main.c        **** } app_mode_t;
