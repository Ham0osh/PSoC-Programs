  36              		.file 1 "main.c"
   1:main.c        **** /* main.c
   2:main.c        ****  * Author: Hamish Johnson
   3:main.c        ****  * Org: Quantum Internet Systems Lab, SFU, Physics
   4:main.c        ****  * Date: March 2026
   5:main.c        ****  *
   6:main.c        ****  * Uses HamflyAPI (hamfly.h) for all gimbal communication.
   7:main.c        ****  *
   8:main.c        ****  * Modes:
   9:main.c        ****  *   STANDBY   passive; pump runs; 1 Hz status if telemetry valid.
  10:main.c        ****  *             Set boresight origin here before entering other modes.
  11:main.c        ****  *   CONTROL   10 Hz QX277 TX.  Joystick (rate) and numpad presets
  12:main.c        ****  *             share the mode — preset executes, settles to within
  13:main.c        ****  *             PRESET_SETTLE_DEG of target (or PRESET_SETTLE_MS
  14:main.c        ****  *             timeout), then joystick resumes automatically.
  15:main.c        ****  *   QUERY     one-shot attr reads with verbose print or 2 s timeout.
  16:main.c        ****  *             No periodic TX; gimbal holds last command.
  17:main.c        ****  *   NUDGE     keyboard-driven absolute accumulation for beam-profiler
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccFpxs5T.s 			page 2


  18:main.c        ****  *             calibration.  Each keypress adds a fixed step to the
  19:main.c        ****  *             accumulated pan/tilt target, clamped to software limits.
  20:main.c        ****  *             Current accumulated position prints after every step.
  21:main.c        ****  *             No joystick input in this mode.
  22:main.c        ****  *
  23:main.c        ****  * Keys — STANDBY:
  24:main.c        ****  *   m  enter CONTROL      q  enter QUERY
  25:main.c        ****  *   n  enter NUDGE        s  toggle ADC stream
  26:main.c        ****  *   j  toggle joystick    l  cycle DEFER/RATE/ABS
  27:main.c        ****  *   c  calibration        k  kill + STANDBY
  28:main.c        ****  *   x  kill + quiet
  29:main.c        ****  *   z  command (0, 0) absolute  (go to boresight)
  30:main.c        ****  *   [  set limit origin at current Euler position
  31:main.c        ****  *      (prints Euler first so you can confirm boresight)
  32:main.c        ****  *
  33:main.c        ****  * Keys — CONTROL (plus all STANDBY keys active):
  34:main.c        ****  *   Numpad presets (require ABS mode via 'l'):
  35:main.c        ****  *     8  tilt +25 deg      2  tilt -25 deg      5  tilt  0 deg
  36:main.c        ****  *     4  pan  -45 deg      6  pan  +45 deg       0  pan   0 deg
  37:main.c        ****  *   (preset executes, joystick resumes automatically after settle)
  38:main.c        ****  *   p  toggle platform-yaw display in 1 Hz diag
  39:main.c        ****  *
  40:main.c        ****  * Keys — QUERY:
  41:main.c        ****  *   a  attr 22 euler       g  attr  4 GPS
  42:main.c        ****  *   b  attr  3 baro        s  attr  1 sysstat
  43:main.c        ****  *   n  attr 12 mag         2  attr  2 platform att
  44:main.c        ****  *   4  attr 48 motor       q  quat crosscheck
  45:main.c        ****  *   t  exit to STANDBY     x  kill + exit
  46:main.c        ****  *
  47:main.c        ****  * Keys — NUDGE:
  48:main.c        ****  *   j  pan  left  (NUDGE_SMALL_DEG)    l  pan  right (NUDGE_SMALL_DEG)
  49:main.c        ****  *   i  tilt up    (NUDGE_SMALL_DEG)    k  tilt down  (NUDGE_SMALL_DEG)
  50:main.c        ****  *   a  pan  left  (NUDGE_LARGE_DEG)    d  pan  right (NUDGE_LARGE_DEG)
  51:main.c        ****  *   w  tilt up    (NUDGE_LARGE_DEG)    s  tilt down  (NUDGE_LARGE_DEG)
  52:main.c        ****  *   (accumulated pan/tilt printed after every step)
  53:main.c        ****  *   t  exit to STANDBY     x  kill + exit
  54:main.c        ****  */
  55:main.c        **** 
  56:main.c        **** #include <project.h>
  57:main.c        **** #include <stdio.h>
  58:main.c        **** #include <math.h>
  59:main.c        **** #include <string.h>
  60:main.c        **** 
  61:main.c        **** #include "hamfly.h"
  62:main.c        **** #include "adc_balanced.h"
  63:main.c        **** #include "joystick.h"
  64:main.c        **** #include "psoc_eeprom.h"
  65:main.c        **** 
  66:main.c        **** /* =========================================================================
  67:main.c        ****  * Timing constants
  68:main.c        ****  * ========================================================================= */
  69:main.c        **** #define TX_BUF_SIZE           160u
  70:main.c        **** #define CONTROL_PERIOD_MS     100u    /* 10 Hz control TX                       */
  71:main.c        **** #define DIAG_PERIOD_MS        1000u   /* 1 Hz diagnostic print                  */
  72:main.c        **** #define QUERY_TIMEOUT_MS      2000u   /* max wait for attr response in QUERY     */
  73:main.c        **** #define PRESET_SETTLE_MS      1500u   /* fallback timeout if threshold not met   */
  74:main.c        **** 
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccFpxs5T.s 			page 3


  75:main.c        **** /* =========================================================================
  76:main.c        ****  * Software limits
  77:main.c        ****  * Limits are relative to the boresight origin set with '[' in STANDBY.
  78:main.c        ****  * All values in degrees.
  79:main.c        ****  * ========================================================================= */
  80:main.c        **** #define LIMIT_PAN_MAX_DEG      15.0f
  81:main.c        **** #define LIMIT_PAN_MIN_DEG     -15.0f
  82:main.c        **** #define LIMIT_TILT_MAX_DEG     15.0f
  83:main.c        **** #define LIMIT_TILT_MIN_DEG    -15.0f
  84:main.c        **** 
  85:main.c        **** /* =========================================================================
  86:main.c        ****  * Nudge step sizes (degrees)
  87:main.c        ****  * ========================================================================= */
  88:main.c        **** #define NUDGE_SMALL_DEG         0.05f  /* jkli — smallest reliable gimbal step  */
  89:main.c        **** #define NUDGE_LARGE_DEG         0.5f   /* wasd — coarse step for beam scanning  */
  90:main.c        **** 
  91:main.c        **** /* =========================================================================
  92:main.c        ****  * Preset settle threshold
  93:main.c        ****  * Joystick resumes when |commanded - actual| < this value on both axes,
  94:main.c        ****  * or after PRESET_SETTLE_MS, whichever comes first.
  95:main.c        ****  * ========================================================================= */
  96:main.c        **** #define PRESET_SETTLE_DEG       0.5f
  97:main.c        **** 
  98:main.c        **** /* =========================================================================
  99:main.c        ****  * Utility macros
 100:main.c        ****  * ========================================================================= */
 101:main.c        **** #define DEG_TO_UNIT(d)   ((float)(d) / 180.0f)
 102:main.c        **** #define UNIT_TO_DEG(u)   ((float)(u) * 180.0f)
 103:main.c        **** #define CLAMP(v,lo,hi)   ((v)<(lo)?(lo):((v)>(hi)?(hi):(v)))
 104:main.c        **** #define FALSE  0u
 105:main.c        **** #define TRUE   1u
 106:main.c        **** #define CH_X   0u
 107:main.c        **** #define CH_Y   1u
 108:main.c        **** 
