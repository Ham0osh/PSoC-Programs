 283:..\..\..\HamFlyAPI\src/hamfly_core_telemetry.c **** // Single round trip gives GPS lock state, rough position, pressure, IMU rate.
 284:..\..\..\HamFlyAPI\src/hamfly_core_telemetry.c **** //
 285:..\..\..\HamFlyAPI\src/hamfly_core_telemetry.c **** // off 0-7   GPS position bytes (mirrors attr 4 lon/lat when GPS locked).
