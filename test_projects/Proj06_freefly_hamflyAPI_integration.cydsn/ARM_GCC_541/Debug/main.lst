   1:main.c        **** /* main.c
   2:main.c        ****  * Author: Hamish Johnson
   3:main.c        ****  * Org: Quantum Internet Systems Lab, SFU, Physics
   4:main.c        ****  * Date: March 2026
   5:main.c        ****  *
   6:main.c        ****  * Uses HamflyAPI (hamfly.h) for all gimbal communication.
   7:main.c        ****  *
   8:main.c        ****  * Modes:
   9:main.c        ****  *   STANDBY      passive, pump runs, 1Hz status if valid
  10:main.c        ****  *   CONTROL      QX277 at 10Hz, joystick or presets
  11:main.c        ****  *   TEST         one-shot attr read, verbose print or timeout
  12:main.c        ****  *   SCAN         exhaustive attr sweep
  13:main.c        ****  *   RESET        attr 382 heading reset sequence
  14:main.c        ****  *   SENSOR       continuous compact sensor stream
  15:main.c        ****  *
  16:main.c        ****  * Keys — STANDBY:
  17:main.c        ****  *   m  toggle STANDBY <-> CONTROL
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccR7vZLd.s 			page 2


  18:main.c        ****  *   t  enter TEST      w  enter SCAN
  19:main.c        ****  *   r  enter RESET     v  enter SENSOR
  20:main.c        ****  *   j  toggle joystick l  cycle DEFER/RATE/ABS
  21:main.c        ****  *   k  kill + STANDBY  x  kill + quiet
  22:main.c        ****  *   s  toggle ADC stream  c  calibration
  23:main.c        ****  *
  24:main.c        ****  * Keys — CONTROL (plus all STANDBY keys):
  25:main.c        ****  *   f  attr 48 one-shot  p  platform yaw toggle
  26:main.c        ****  *   0  home  1  pan+45   2  pan-45
  27:main.c        ****  *   3  tilt+30  4  tilt-30  5  pan+90
  28:main.c        ****  *
  29:main.c        ****  * Keys — TEST:
  30:main.c        ****  *   a  attr 22 euler    g  attr 4 GPS
  31:main.c        ****  *   b  attr 3 baro      s  attr 1 sysstat
  32:main.c        ****  *   n  attr 12 mag      2  attr 2 platform att
  33:main.c        ****  *   4  attr 48 motor    q  quat crosscheck
  34:main.c        ****  *   t  exit             k/x  kill + exit
  35:main.c        ****  *
  36:main.c        ****  * Keys — RESET:  x/k abort
  37:main.c        ****  * Keys — SENSOR: any key exits
  38:main.c        ****  */
  39:main.c        **** 
