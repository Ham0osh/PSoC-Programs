# proj00_custom_blinker
# 2025-08-29 22:58:49Z

# IO_0@[IOP=(1)][IoId=(0)] is reserved: SWDDebugEnabled
dont_use_io iocell 1 0
# IO_1@[IOP=(1)][IoId=(1)] is reserved: SWDDebugEnabled
dont_use_io iocell 1 1
# IO_3@[IOP=(1)][IoId=(3)] is reserved: SWDDebugEnabled
dont_use_io iocell 1 3
set_location "ClockBlock" clockblockcell -1 -1 0
set_io "Pin_LED(0)" iocell 2 1
set_io "Pin_SW1(0)" iocell 2 2
set_location "\Timer:TimerUDB:capt_fifo_load\" 0 4 1 2
set_location "\Timer:TimerUDB:status_tc\" 0 4 0 2
set_location "\Timer:TimerUDB:trig_reg\" 0 4 0 0
set_location "\Timer:TimerUDB:sCTRLReg:SyncCtl:ctrlreg\" 1 4 6
set_location "\Timer:TimerUDB:rstSts:stsreg\" 0 4 4
set_location "\Timer:TimerUDB:sT16:timerdp:u0\" 1 4 2
set_location "\Timer:TimerUDB:sT16:timerdp:u1\" 0 4 2
set_location "Timer_Int" interrupt -1 -1 0
set_location "\Timer:TimerUDB:capture_last\" 0 4 1 0
set_location "\Timer:TimerUDB:int_capt_count_1\" 1 4 0 2
set_location "\Timer:TimerUDB:int_capt_count_0\" 1 4 0 1
set_location "\Timer:TimerUDB:capt_int_temp\" 0 4 1 1
set_location "\Timer:TimerUDB:trig_rise_detected\" 0 4 0 1
set_location "\Timer:TimerUDB:trig_fall_detected\" 0 4 0 3
