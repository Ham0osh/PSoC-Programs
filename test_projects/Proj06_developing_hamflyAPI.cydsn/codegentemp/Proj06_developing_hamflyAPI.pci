# Proj06_developing_hamflyAPI
# 2026-03-20 01:05:12Z

# IO_0@[IOP=(1)][IoId=(0)] is reserved: SWDDebugEnabled
dont_use_io iocell 1 0
# IO_1@[IOP=(1)][IoId=(1)] is reserved: SWDDebugEnabled
dont_use_io iocell 1 1
# IO_3@[IOP=(1)][IoId=(3)] is reserved: SWDDebugEnabled
dont_use_io iocell 1 3
set_io "VRx(0)" iocell 0 0
set_io "Rx_1(0)" iocell 12 6
set_io "Tx_1(0)" iocell 12 7
set_io "VRy(0)" iocell 0 1
set_io "Rx_2(0)" iocell 12 4
set_io "Tx_2(0)" iocell 12 5
set_io "Pin_LED(0)" iocell 2 1
set_io "Pin_Sensitivity(0)" iocell 12 2
set_location "\ADC_DelSig_1:DSM\" dsmodcell -1 -1 0
