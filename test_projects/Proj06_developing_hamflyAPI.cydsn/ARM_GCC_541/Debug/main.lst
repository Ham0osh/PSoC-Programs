   1:main.c        **** /* main.c
   2:main.c        ****  * HamflyAPI example — PSoC 5LP
   3:main.c        ****  * Joystick gimbal control + one-shot attr test queries.
   4:main.c        ****  *
   5:main.c        ****  * Modes:
   6:main.c        ****  *   STANDBY      passive, pump runs, no TX
   7:main.c        ****  *   CONTROL      QX277 at 10 Hz via joystick
   8:main.c        ****  *   TEST         one-shot attr read, print response or timeout
   9:main.c        ****  *
  10:main.c        ****  * Keys — STANDBY:
  11:main.c        ****  *   m  toggle STANDBY <-> CONTROL
  12:main.c        ****  *   t  enter TEST mode
  13:main.c        ****  *   l  cycle DEFER -> RATE -> ABSOLUTE -> DEFER
  14:main.c        ****  *   k  kill + STANDBY
  15:main.c        ****  *
  16:main.c        ****  * Keys — TEST:
  17:main.c        ****  *   a  attr 22  gimbal Euler
ARM GAS  C:\Users\JENNEW~1\AppData\Local\Temp\ccz5kgXS.s 			page 2


  18:main.c        ****  *   g  attr  4  GPS
  19:main.c        ****  *   b  attr  3  baro
  20:main.c        ****  *   s  attr  1  system status
  21:main.c        ****  *   n  attr 12  magnetometer
  22:main.c        ****  *   t  exit TEST
  23:main.c        ****  *   k  kill + exit
  24:main.c        ****  */
  25:main.c        **** 
