  32:main.c        **** // Handle writing the command for the API
  33:main.c        **** int ff_api_encode_control(uint8_t *out_buf, uint16_t *out_len)
  34:main.c        **** {
  35:main.c        ****     QX_TxMsgOptions_t options;
  36:main.c        ****     QX_InitTxOptions(&options);
  37:main.c        ****     options.Target_Addr = QX_DEV_ID_GIMBAL;
  38:main.c        ****     options.TransReq_Addr = QX_DEV_ID_BROADCAST;
  39:main.c        ****     options.RespReq_Addr = QX_DEV_ID_BROADCAST;
  40:main.c        **** 
  41:main.c        ****     // Build the message
