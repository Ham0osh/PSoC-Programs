  46:main.c        ****     TxMsg.Header.Attrib = 277;
  47:main.c        ****     TxMsg.Header.Type = QX_MSG_TYPE_WRITE_ABS;
  48:main.c        ****     TxMsg.Header.Target_Addr = options.Target_Addr;
  49:main.c        ****     TxMsg.Header.TransReq_Addr = options.TransReq_Addr;
  50:main.c        ****     TxMsg.Header.RespReq_Addr = options.RespReq_Addr;
  51:main.c        ****     TxMsg.Header.Source_Addr = QX_Clients[0].Address;
  52:main.c        ****     TxMsg.Header.FF_Ext = options.FF_Ext;
  53:main.c        ****     TxMsg.Header.AddCRC32 = options.use_CRC32;
  54:main.c        **** 
  55:main.c        ****     QX_TxMsg_Setup(&TxMsg);
  56:main.c        ****     TxMsg.Parse_Type = QX_PARSE_TYPE_WRITE_ABS_SEND;
  57:main.c        ****     TxMsg.MsgBuf_p = QX_Clients[0].Parser_CB(&TxMsg);
  58:main.c        ****     QX_TxMsg_Finish(&TxMsg);
  59:main.c        **** 
  60:main.c        ****     // Copy the encoded message to out_buf
  61:main.c        ****     for (uint16_t i = 0; i < TxMsg.MsgBuf_MsgLen; i++)
  62:main.c        ****         out_buf[i] = TxMsg.MsgBufStart_p[i];
  63:main.c        **** 
  64:main.c        ****     *out_len = TxMsg.MsgBuf_MsgLen;
  65:main.c        ****     return 0; // success
  66:main.c        **** }
