  21:main.c        **** // Example Rx handler
  22:main.c        **** void UART_ReceiveHandler(void)
  23:main.c        **** {
  24:main.c        ****     uint8_t rxByte;
  25:main.c        ****     // Poll for received bytes (or use interrupt if preferred)
  26:main.c        ****     while ((rxByte = UART_GetChar()) != 0)
  27:main.c        ****     {
  28:main.c        ****         // Pass each received byte to the MOVI API
  29:main.c        ****         QX_StreamRxCharSM(QX_COMMS_PORT_UART, rxByte);
  30:main.c        ****     }
